<div class="cthulhu-eye-container" id="cthulhu-container">
  <div class="eye-stack" id="eye-stack">
    <!-- Eyeball layer: behind the base, shows the iris -->
    <div class="eye-ball-layer">
      <img src="/Spec/eyeball_layer.png" alt="" id="eyeball-img" />
      <canvas id="pupil-canvas"></canvas>
    </div>

    <!-- Base layer: tentacles + eye socket, frames the eyeball -->
    <div class="eye-base-layer">
      <img src="/Spec/base_layer.png" alt="" id="base-img" />
    </div>

    <!-- Particle canvas: dripping particles from socket -->
    <canvas id="particle-canvas"></canvas>
  </div>
</div>

<style>
  /* Pure black background */
  :global(body) {
    background: #000 !important;
  }

  .cthulhu-eye-container {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 0;
  }

  .eye-stack {
    position: relative;
    width: 520px;
    height: 520px;
  }

  .eye-ball-layer {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .eye-ball-layer img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #pupil-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .eye-base-layer {
    position: absolute;
    inset: 0;
    z-index: 2;
  }

  .eye-base-layer img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #particle-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  @media (max-width: 600px) {
    .eye-stack {
      width: 320px;
      height: 320px;
    }
  }
</style>

<script>
  const container = document.getElementById('cthulhu-container');
  const eyeStack = document.getElementById('eye-stack');
  const pupilCanvas = document.getElementById('pupil-canvas');
  const pupilCtx = pupilCanvas.getContext('2d');
  const particleCanvas = document.getElementById('particle-canvas');
  const particleCtx = particleCanvas.getContext('2d');

  // ── Configurable parameters ──────────────────────────────
  const CONFIG = {
    // Eye socket center (normalized 0-1 within the 1024x1024 image)
    socketCenterX: 0.5,
    socketCenterY: 0.48,
    // Socket radius as fraction of image width
    socketRadius: 0.18,
    // Max pupil deviation as fraction of image width
    maxPupilDeviation: 0.055,
    // Pupil ellipse size as fraction of image width
    pupilWidth: 0.065,
    pupilHeight: 0.08,
    // Whole eye follow speed (lower = slower/smoother)
    lerpFactor: 0.04,
    // Particle spawn rate (particles per second)
    particleRate: 15,
    // Particle lifespan in seconds
    particleLifespan: 4,
    // Gravity on particles
    gravity: 0.25,
  };

  // ── State ────────────────────────────────────────────────
  let mouseX = window.innerWidth / 2;
  let mouseY = window.innerHeight / 2;
  let eyeCurrentX = mouseX;
  let eyeCurrentY = mouseY;
  let eyeSize = eyeStack.clientWidth;
  let dpr = Math.min(window.devicePixelRatio || 1, 2);

  // ── Setup canvases with DPR ──────────────────────────────
  function setupCanvas(canvas, ctx) {
    const w = eyeSize * dpr;
    const h = eyeSize * dpr;
    canvas.width = w;
    canvas.height = h;
    canvas.style.width = eyeSize + 'px';
    canvas.style.height = eyeSize + 'px';
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
  }

  function setupAllCanvases() {
    eyeSize = eyeStack.clientWidth;
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    setupCanvas(pupilCanvas, pupilCtx);
    setupCanvas(particleCanvas, particleCtx);
  }
  setupAllCanvases();

  window.addEventListener('resize', setupAllCanvases);

  // ── Mouse tracking ───────────────────────────────────────
  document.addEventListener('mousemove', (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
  });

  // ── Pupil drawing ────────────────────────────────────────
  function getSocketCenter() {
    return {
      x: eyeSize * CONFIG.socketCenterX,
      y: eyeSize * CONFIG.socketCenterY,
    };
  }

  function drawPupil() {
    pupilCtx.clearRect(0, 0, eyeSize, eyeSize);

    const socket = getSocketCenter();
    const socketRadius = eyeSize * CONFIG.socketRadius;
    const maxOffset = eyeSize * CONFIG.maxPupilDeviation;

    // Get mouse relative to the eye stack center on screen
    const rect = eyeStack.getBoundingClientRect();
    const eyeScreenX = rect.left + socket.x;
    const eyeScreenY = rect.top + socket.y;

    const dx = mouseX - eyeScreenX;
    const dy = mouseY - eyeScreenY;
    const dist = Math.sqrt(dx * dx + dy * dy);

    // Map to socket-relative offset, clamped to max
    const socketDist = Math.min(dist, socketRadius);
    const ratio = socketDist / socketRadius;
    const offsetDist = ratio * maxOffset;
    const angle = Math.atan2(dy, dx);

    const pupilX = socket.x + Math.cos(angle) * offsetDist;
    const pupilY = socket.y + Math.sin(angle) * offsetDist;

    // Draw black elliptical pupil
    const pw = eyeSize * CONFIG.pupilWidth;
    const ph = eyeSize * CONFIG.pupilHeight;

    pupilCtx.fillStyle = '#000';
    pupilCtx.beginPath();
    pupilCtx.ellipse(pupilX, pupilY, pw, ph, 0, 0, Math.PI * 2);
    pupilCtx.fill();

    // Subtle inner shadow for depth
    const gradient = pupilCtx.createRadialGradient(pupilX, pupilY, pw * 0.3, pupilX, pupilY, pw);
    gradient.addColorStop(0, 'rgba(0,0,0,0.9)');
    gradient.addColorStop(1, 'rgba(0,0,0,0.6)');
    pupilCtx.fillStyle = gradient;
    pupilCtx.beginPath();
    pupilCtx.ellipse(pupilX, pupilY, pw, ph, 0, 0, Math.PI * 2);
    pupilCtx.fill();
  }

  // ── Particle system ──────────────────────────────────────
  const particles = [];
  let spawnAccum = 0;
  let lastTime = performance.now();

  class Particle {
    constructor(x, y) {
      this.x = x + (Math.random() - 0.5) * 20;
      this.y = y;
      this.vx = (Math.random() - 0.5) * 1.5;
      this.vy = Math.random() * 1.5 + 0.5;
      this.life = 1;
      this.decay = 1 / (CONFIG.particleLifespan * 60); // per-frame at 60fps
      this.size = Math.random() * 3 + 1.5;
      // Mix of green and red
      if (Math.random() < 0.5) {
        // Green-ish
        this.r = Math.floor(Math.random() * 60);
        this.g = Math.floor(Math.random() * 150 + 105);
      } else {
        // Red-ish
        this.r = Math.floor(Math.random() * 100 + 155);
        this.g = Math.floor(Math.random() * 50);
      }
      this.b = Math.floor(Math.random() * 20);
      this.a = 1;
    }

    update(dt) {
      this.x += this.vx;
      this.y += this.vy;
      this.vy += CONFIG.gravity;
      this.life -= this.decay * (dt / 16.667); // normalize to 60fps
      this.a = Math.max(0, this.life);
    }

    draw(ctx) {
      ctx.fillStyle = `rgba(${this.r},${this.g},${this.b},${this.a})`;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fill();
    }

    get alive() {
      return this.life > 0;
    }
  }

  function spawnParticles(dt) {
    const nsPerParticle = 1000 / CONFIG.particleRate;
    spawnAccum += dt;

    const socket = getSocketCenter();
    const socketRadius = eyeSize * CONFIG.socketRadius;
    // Spawn at bottom of socket
    const spawnY = socket.y + socketRadius * 0.8;

    while (spawnAccum >= nsPerParticle) {
      spawnAccum -= nsPerParticle;
      particles.push(new Particle(socket.x, spawnY));
    }
  }

  function updateParticles(dt) {
    for (let i = particles.length - 1; i >= 0; i--) {
      particles[i].update(dt);
      if (!particles[i].alive) {
        particles.splice(i, 1);
      }
    }
  }

  function drawParticles() {
    particleCtx.clearRect(0, 0, eyeSize, eyeSize);
    for (const p of particles) {
      p.draw(particleCtx);
    }
  }

  // ── Whole eye follow (lerp) ──────────────────────────────
  function updateEyePosition() {
    eyeCurrentX += (mouseX - eyeCurrentX) * CONFIG.lerpFactor;
    eyeCurrentY += (mouseY - eyeCurrentY) * CONFIG.lerpFactor;
    container.style.left = eyeCurrentX + 'px';
    container.style.top = eyeCurrentY + 'px';
  }

  // ── Main render loop ─────────────────────────────────────
  function loop(timestamp) {
    const dt = Math.min(timestamp - lastTime, 50); // cap to avoid spiral
    lastTime = timestamp;

    updateEyePosition();
    drawPupil();
    spawnParticles(dt);
    updateParticles(dt);
    drawParticles();

    requestAnimationFrame(loop);
  }

  requestAnimationFrame(loop);
</script>
